<turbo-frame id="reader-result">
    {% if document %}
        <section class="overflow-hidden border border-[#333] bg-[#111]/90" data-controller="markdown-view">
            <div class="flex flex-col gap-4 border-b border-[#333] p-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                    <p class="m-0 text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">Ready</p>
                    <h2 class="mt-2 mb-1 truncate text-lg font-semibold text-white">{{ document.title }}</h2>
                    <p class="m-0 break-all text-sm text-gray-400">{{ document.canonicalUrl }}</p>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                    <a
                        href="{{ path('app_reader_raw', { url: document.canonicalUrl }) }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="border border-[#444] bg-transparent px-3 py-1.5 text-xs text-gray-400 transition-colors hover:border-gray-500 hover:text-white"
                    >
                        Raw route
                    </a>
                    <button
                        type="button"
                        data-action="markdown-view#copyRaw"
                        data-markdown-view-target="copyButton"
                        class="cursor-pointer border border-[#444] bg-transparent px-3 py-1.5 text-xs text-gray-400 transition-colors hover:border-gray-500 hover:text-white"
                    >
                        Copy
                    </button>
                    <button
                        type="button"
                        data-action="markdown-view#toggleMode"
                        data-markdown-view-target="toggleButton"
                        class="cursor-pointer border border-[#444] bg-transparent px-3 py-1.5 text-xs text-gray-400 transition-colors hover:border-gray-500 hover:text-white"
                    >
                        Raw
                    </button>
                </div>
            </div>

            <div class="max-h-[80vh] overflow-auto p-4 font-mono text-sm">
                <textarea hidden data-markdown-view-target="source">{{ document.markdown }}</textarea>
                <div data-markdown-view-target="body"></div>
            </div>
        </section>
    {% elseif error %}
        <section class="overflow-hidden border border-rose-900/60 bg-rose-950/20">
            <div class="border-b border-rose-900/60 px-4 py-3">
                <p class="m-0 text-xs font-semibold uppercase tracking-[0.18em] text-rose-300">Unable to read URL</p>
            </div>
            <div class="p-4">
                <p class="m-0 text-sm text-rose-100">{{ error }}</p>
                {% if hint %}
                    <p class="mt-3 mb-0 text-sm text-rose-200/80">{{ hint }}</p>
                {% endif %}
                {% if requested_url is not empty %}
                    <p class="mt-3 mb-0 break-all font-mono text-xs text-rose-200/70">{{ requested_url }}</p>
                {% endif %}
            </div>
        </section>
    {% else %}
        <div></div>
    {% endif %}
</turbo-frame>
