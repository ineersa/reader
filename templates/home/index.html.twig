{% extends 'base.html.twig' %}

{% block title %}reader{% endblock %}

{% block body %}
    <div class="flex min-h-screen flex-col bg-[#0a0a0a]" data-controller="reader-page">
        <main class="flex-1">
            <div class="mx-auto flex w-full max-w-[1200px] flex-col gap-8 px-6 py-10 lg:max-w-[1040px] lg:px-8 lg:py-14 xl:max-w-[1200px]">
                <header class="mt-4 w-full text-center lg:mt-[5vh]">
                    <h1 class="m-0 text-[clamp(2rem,4.5vw,3.5rem)] tracking-tight text-white">reader</h1>
                    <p class="mt-3 text-base text-gray-400 sm:text-lg">Turn any web page into LLM-ready markdown.</p>
                </header>

                <section class="grid w-full gap-4 text-sm text-gray-300 lg:grid-cols-3">
                    <article class="border border-[#222] bg-[#101010] p-5 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">How it works</h2>
                        <p class="mt-3 mb-0 leading-7">
                            Paste a URL and reader will fetch the page, identify the main content, normalize links, and convert the result into markdown optimized for LLM ingestion.
                        </p>
                        <p class="mt-3 mb-0 leading-7">
                            The conversion pipeline is based on <a class="text-blue-400 hover:text-blue-300" href="https://github.com/ineersa/html2markdown" target="_blank" rel="noopener noreferrer">ineersa/html2markdown</a>.
                        </p>
                    </article>

                    <article class="border border-[#222] bg-[#101010] p-5 text-left text-gray-400 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Limits</h2>
                        <p class="mt-3 mb-0 leading-7">Up to 10 requests per 10 minutes per IP.</p>
                        <p class="mt-3 mb-0 leading-7">Use the rendered view for reading or switch to raw markdown and copy it directly.</p>
                    </article>

                    <article class="border border-[#222] bg-[#101010] p-5 text-left text-gray-400 shadow-[0_18px_54px_rgba(0,0,0,0.35)]">
                        <h2 class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Raw route</h2>
                        <p class="mt-3 mb-0 leading-7">Use <code>/r/{URL}</code> to get the markdown response directly, similar to Jina Reader.</p>
                        <p class="mt-3 mb-0 leading-7">It returns plain text markdown, so it works well for scripts, agents, shortcuts, and quick copy-paste flows.</p>
                    </article>
                </section>

                <section class="w-full">
                    <div class="border border-[#222] bg-[#101010] p-4 shadow-[0_18px_54px_rgba(0,0,0,0.5)] sm:p-5">
                        <form
                            method="get"
                            action="{{ path('app_reader_fetch') }}"
                            data-reader-page-target="form"
                            data-action="submit->reader-page#start"
                            data-turbo-frame="reader-result"
                        >
                            <label class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-gray-500" for="reader-url">URL</label>
                            <div class="grid grid-cols-1 gap-2 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-3">
                                <input
                                    id="reader-url"
                                    name="url"
                                    type="url"
                                    value="{{ requested_url|default('') }}"
                                    placeholder="https://example.com/article"
                                    autocomplete="url"
                                    required
                                    data-reader-page-target="input"
                                    class="w-full border border-[#444] bg-[#1a1a1a] p-3 text-gray-100 outline-none focus:border-gray-300 focus:ring-1 focus:ring-gray-300 placeholder-gray-600"
                                >
                                <button
                                    type="submit"
                                    data-reader-page-target="submitButton"
                                    class="flex min-w-[132px] cursor-pointer items-center justify-center gap-2 border-none bg-white px-4 py-3 font-semibold text-black transition-colors hover:bg-gray-200"
                                >
                                    <span data-reader-page-target="spinner" class="hidden h-4 w-4 animate-spin rounded-full border-2 border-black border-t-transparent"></span>
                                    <span data-reader-page-target="submitLabel">Read</span>
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="mt-8" data-reader-page-target="resultFrame">
                        {% include 'home/_result_frame.html.twig' with {
                            document: document|default(null),
                            error: error|default(null),
                            hint: hint|default(null),
                            requested_url: requested_url|default('')
                        } only %}
                    </div>
                </section>
            </div>
        </main>

        <footer class="border-t border-[#222] bg-[#0a0a0a] py-6">
            <div class="mx-auto flex w-full max-w-[1200px] flex-col items-center px-6 lg:max-w-[1040px] lg:px-8 xl:max-w-[1200px]">
                <div class="mb-3 flex space-x-4">
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="mailto:ineersa.c@gmail.com">
                    <span class="sr-only">mail</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                        <title>Mail</title>
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                    </svg>
                    </a>
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://github.com/ineersa">
                    <span class="sr-only">github</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                        <title>Github</title>
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
                    </svg>
                    </a>
                    <a class="text-sm text-gray-500 transition hover:text-gray-300" target="_blank" rel="noopener noreferrer" href="https://www.linkedin.com/in/illia-vasylevskyi-b7353558/">
                    <span class="sr-only">linkedin</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current text-gray-400 transition-colors hover:text-white">
                        <title>Linkedin</title>
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                    </svg>
                    </a>
                </div>
                <div class="mb-2 flex space-x-2 text-sm text-gray-500">
                    <div>Illia Vasylevskyi</div>
                    <div>•</div>
                    <div>© {{ "now"|date("Y") }}</div>
                    <div>•</div>
                    <a href="{{ path('app_home') }}" class="hover:text-gray-300">reader</a>
                </div>
            </div>
        </footer>
    </div>
{% endblock %}
